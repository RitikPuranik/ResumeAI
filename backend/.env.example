PORT=5000
MONGO_URI=mongodb://localhost:27017/ai_resume_interview
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Google Gemini API (FREE) — all AI features
# Get free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Razorpay — only 2 keys needed
# Get keys at: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Cloudinary — free tier, 25GB storage
# Get at: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
